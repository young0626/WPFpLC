                            Content="向后"
                            Style="{StaticResource ButtonStyle1}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                    <i:InvokeCommandAction Command="{Binding BackwardMouseDownCommand}" />
                                </i:EventTrigger>
                                <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                    <i:InvokeCommandAction Command="{Binding BackwardMouseUpCommand}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
