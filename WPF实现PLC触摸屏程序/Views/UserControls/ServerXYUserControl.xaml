<UserControl
    x:Class="WPF实现PLC触摸屏程序.Views.UserControls.ServerXYUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:WPF实现PLC触摸屏程序.Views.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:usercontrols="clr-namespace:WPF实现PLC触摸屏程序.ViewModels.UserControls"
    d:DataContext="{d:DesignInstance Type=usercontrols:ServerXYViewModel}"
    d:DesignHeight="750"
    d:DesignWidth="1200"
    Background="#009b9b"
    mc:Ignorable="d">

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Unloaded">
            <i:InvokeCommandAction Command="{Binding UnloadedCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="120" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">


            <TextBlock
                FontSize="24"
                Foreground="White"
                Text="伺服控制页">
                <TextBlock.TextDecorations>
                    <TextDecoration
                        PenOffset="10"
                        PenOffsetUnit="Pixel"
                        PenThicknessUnit="Pixel">
                        <TextDecoration.Pen>
                            <Pen Thickness="5">
                                <Pen.Brush>
                                    <LinearGradientBrush Opacity="0.8" StartPoint="0,0.5" EndPoint="1,0.5">
                                        <LinearGradientBrush.GradientStops>
                                            <GradientStop Offset="0" Color="Red" />
                                            <GradientStop Offset="1" Color="Blue" />
                                        </LinearGradientBrush.GradientStops>
                                    </LinearGradientBrush>
                                </Pen.Brush>
                                <Pen.DashStyle>
                                    <DashStyle Dashes="1,2,3" />
                                </Pen.DashStyle>
                            </Pen>
                        </TextDecoration.Pen>
                    </TextDecoration>
                </TextBlock.TextDecorations>
            </TextBlock>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>

            <Grid
                Grid.Column="0"
                Margin="0,0,0,30"
                HorizontalAlignment="Center"
                ShowGridLines="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="0.5*" />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition Height="1.5*" />
                    <RowDefinition Height="1.5*" />
                </Grid.RowDefinitions>

                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="22"
                    Foreground="White"
                    Text="X轴" />

                <Grid Grid.Row="1" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock
                            Margin="0,0,0,10"
                            Foreground="#ffffff"
                            Text="当前位置" />
                        <WrapPanel>
                            <TextBox
                                Style="{StaticResource TextBoxStyle1}"
                                Template="{StaticResource FilletTextBox1}"
                                Text="{Binding XaxisModel.CurrentLocation}" />
                            <TextBlock Style="{StaticResource TextBlockStyle2}" Text="MM" />
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock
                            Margin="0,0,0,10"
                            Foreground="#ffffff"
                            Text="当前速度" />
                        <WrapPanel VerticalAlignment="Center">
                            <TextBox
                                Style="{StaticResource TextBoxStyle1}"
                                Template="{StaticResource FilletTextBox1}"
                                Text="{Binding XaxisModel.CurrentSpeed}" />
                            <TextBlock Style="{StaticResource TextBlockStyle2}" Text="MM/S" />
                        </WrapPanel>
                    </StackPanel>
                </Grid>

                <Grid
                    Grid.Row="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <WrapPanel Grid.Row="0">
                        <TextBlock Style="{StaticResource TextBlockStyle2}" Text="点动速度" />
                        <TextBox
                            Name="xJogSpeed"
                            Style="{StaticResource TextBoxStyle2}"
                            Template="{StaticResource FilletTextBox2}"
                            Text="{Binding XaxisModel.JogSpeed}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="GotFocus">
                                    <i:InvokeCommandAction Command="{Binding GotFocusXJogSpeed}" />
                                </i:EventTrigger>
                                <i:EventTrigger EventName="LostFocus">
                                    <i:InvokeCommandAction Command="{Binding LostFocusXJogSpeed}" CommandParameter="{Binding ElementName=xJogSpeed, Path=Text}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </TextBox>
                        <TextBlock Style="{StaticResource TextBlockStyle2}" Text="MM/S" />
                    </WrapPanel>

                    <WrapPanel Grid.Row="1" Margin="0,15,0,0">
                        <Button Content="向前" Style="{StaticResource ButtonStyle1}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="PreviewMouseLeftButtonDown">
                                    <i:InvokeCommandAction Command="{Binding ForwardMouseDownCommand}" />
                                </i:EventTrigger>
                                <i:EventTrigger EventName="PreviewMouseLeftButtonUp">
                                    <i:InvokeCommandAction Command="{Binding ForwardMouseUpCommand}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
