                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </TextBox>
                    </WrapPanel>

                    <WrapPanel
                        Grid.Row="2"
                        Grid.Column="1"
                        VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource TextBlockStyle1}" Text="预留位2" />
                        <TextBox
                            Name="yReservedPosition2"
                            Style="{StaticResource TextBoxStyle2}"
                            Template="{StaticResource FilletTextBox2}"
                            Text="{Binding YaxisModel.ReservedPosition2}">
                            <i:Interaction.Triggers>
                                <i:EventTrigger EventName="GotFocus">
                                    <i:InvokeCommandAction Command="{Binding GotFocusYReservedPosition2}" />
                                </i:EventTrigger>
                                <i:EventTrigger EventName="LostFocus">
                                    <i:InvokeCommandAction Command="{Binding LostFocusYReservedPosition2}" CommandParameter="{Binding ElementName=yReservedPosition2, Path=Text}" />
                                </i:EventTrigger>
                            </i:Interaction.Triggers>
                        </TextBox>
                    </WrapPanel>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
