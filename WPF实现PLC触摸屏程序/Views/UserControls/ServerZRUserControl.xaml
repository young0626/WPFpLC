                                        </i:InvokeCommandAction>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                            </TextBox>
                            <TextBlock Style="{StaticResource TextBlockStyle2}" Text="MM/S" />
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="0" Grid.Column="1">
                        <TextBlock
                            Margin="0,0,0,10"
                            Foreground="#ffffff"
                            Text="定位位置" />
                        <WrapPanel VerticalAlignment="Center">
                            <TextBox
                                Name="rLocation"
                                Style="{StaticResource TextBoxStyle2}"
                                Tag="DB8.DBD96"
                                Template="{StaticResource FilletTextBox2}"
                                Text="{Binding RaxisModel.Location}">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="GotFocus">
                                        <i:InvokeCommandAction Command="{Binding GotFocus}" />
                                    </i:EventTrigger>
                                    <i:EventTrigger EventName="LostFocus">
                                        <i:InvokeCommandAction Command="{Binding LostFocus}">
                                            <i:InvokeCommandAction.CommandParameter>
                                                <MultiBinding Converter="{StaticResource MultiBindingConverter}">
                                                    <MultiBinding.Bindings>
                                                        <Binding ElementName="rLocation" Path="Tag" />
