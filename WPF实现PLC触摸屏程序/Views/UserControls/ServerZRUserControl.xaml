                        </WrapPanel>
                    </StackPanel>

                    <WrapPanel
                        Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="2"
                        Margin="0,15,0,0"
                        HorizontalAlignment="Center">
                        <TextBlock
                            VerticalAlignment="Center"
                            Foreground="#ffffff"
                            Text="定位控制" />
                        <Button
                            Margin="10,0,0,0"
                            Content="定位启动"
                            Style="{StaticResource ButtonStyle1}">
