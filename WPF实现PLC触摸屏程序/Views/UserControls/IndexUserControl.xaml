<UserControl
    x:Class="WPF实现PLC触摸屏程序.Views.UserControls.IndexUserControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:WPF实现PLC触摸屏程序.Views.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="750"
    d:DesignWidth="1200"
    Background="#8080c0"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Height" Value="30" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Name="border"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Black"
                            BorderThickness="0"
                            CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style
            x:Key="ButtonStyle1"
            BasedOn="{StaticResource ButtonStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="#ffc469" />
            <Setter Property="Width" Value="70" />
        </Style>

        <Style
            x:Key="ButtonStyle2"
            BasedOn="{StaticResource ButtonStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="#b04f22" />
            <Setter Property="Foreground" Value="#ffffff" />
            <Setter Property="Width" Value="80" />
        </Style>

        <Style
            x:Key="ButtonStyle3"
            BasedOn="{StaticResource ButtonStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="#1085a8" />
            <Setter Property="Foreground" Value="#ffffff" />
            <Setter Property="Width" Value="70" />
        </Style>

        <Style
            x:Key="ButtonStyle4"
            BasedOn="{StaticResource ButtonStyle}"
            TargetType="Button">
            <Setter Property="Background" Value="#0d436e" />
            <Setter Property="Foreground" Value="#ffffff" />
            <Setter Property="Width" Value="140" />
        </Style>

        <Style x:Key="TextBoxStyle" TargetType="TextBox">
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="Width" Value="80" />
            <Setter Property="Height" Value="25" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <!--<Setter Property="Text" Value="12.345"/>-->
        </Style>

        <Style
            x:Key="TextBoxStyle1"
            BasedOn="{StaticResource TextBoxStyle}"
            TargetType="TextBox">
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="25" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="FontSize" Value="10" />
            <!--<Setter Property="Text" Value="1234"/>-->
        </Style>

        <ControlTemplate x:Key="FilletTextBox" TargetType="{x:Type TextBox}">
            <Border Background="#ffffff" CornerRadius="0">
                <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center" />
            </Border>
        </ControlTemplate>

        <Style x:Key="TextBlockStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="EllipseStyle" TargetType="Ellipse">
            <Setter Property="Fill" Value="#6d6d6d" />
            <Setter Property="Width" Value="25" />
            <Setter Property="Height" Value="25" />
            <Setter Property="Margin" Value="10,0,0,0" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="120" />
            <RowDefinition />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>

        <Grid
            Grid.ColumnSpan="3"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <TextBlock
                FontSize="24"
                Foreground="White"
                Text="主页面">
                <TextBlock.TextDecorations>
                    <TextDecoration
                        PenOffset="10"
                        PenOffsetUnit="Pixel"
                        PenThicknessUnit="Pixel">
                        <TextDecoration.Pen>
                            <Pen Thickness="5">
                                <Pen.Brush>
                                    <LinearGradientBrush Opacity="0.8" StartPoint="0,0.5" EndPoint="1,0.5">
                                        <LinearGradientBrush.GradientStops>
                                            <GradientStop Offset="0" Color="Red" />
                                            <GradientStop Offset="1" Color="Blue" />
                                        </LinearGradientBrush.GradientStops>
                                    </LinearGradientBrush>
                                </Pen.Brush>
                                <Pen.DashStyle>
                                    <DashStyle Dashes="1,2,3" />
                                </Pen.DashStyle>
                            </Pen>
                        </TextDecoration.Pen>
                    </TextDecoration>
                </TextBlock.TextDecorations>
            </TextBlock>
        </Grid>

        <Grid
            Grid.Row="1"
            Grid.Column="0"
            Height="280"
            HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0" HorizontalAlignment="Left">
                <TextBlock Margin="0,10" Text="设备操作模式" />
                <Button Content="手动" Style="{StaticResource ButtonStyle1}" />
            </StackPanel>
            <StackPanel Grid.Row="1" HorizontalAlignment="Left">
                <WrapPanel Margin="0,10">
                    <TextBlock VerticalAlignment="Center" Text="设备复位完成" />
                    <Ellipse Style="{StaticResource EllipseStyle}" />
                </WrapPanel>
                <Button
                    HorizontalAlignment="Left"
                    Content="设备复位"
                    Style="{StaticResource ButtonStyle2}" />
            </StackPanel>
            <StackPanel Grid.Row="2" HorizontalAlignment="Left">
                <TextBlock Margin="0,10" Text="R轴吸盘" />
                <Button Content="吸真空" Style="{StaticResource ButtonStyle3}" />
            </StackPanel>
        </Grid>

        <Grid
            Grid.Row="1"
            Grid.Column="1"
            Height="240"
            HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Foreground="#ffffff" Text="偏移量1" />
                <WrapPanel Margin="0,5">
                    <TextBlock Style="{StaticResource TextBlockStyle}" Text="X" />
                    <TextBox Style="{StaticResource TextBoxStyle}" Template="{StaticResource FilletTextBox}" />
                </WrapPanel>
                <WrapPanel Margin="0,5">
                    <TextBlock Style="{StaticResource TextBlockStyle}" Text="Y" />
                    <TextBox Style="{StaticResource TextBoxStyle}" Template="{StaticResource FilletTextBox}" />
                </WrapPanel>
                <WrapPanel Margin="0,5">
                    <TextBlock Style="{StaticResource TextBlockStyle}" Text="R" />
                    <TextBox Style="{StaticResource TextBoxStyle}" Template="{StaticResource FilletTextBox}" />
                </WrapPanel>
            </StackPanel>

            <StackPanel Grid.Row="2">
                <TextBlock Foreground="#ffffff" Text="偏移量2" />
                <WrapPanel Margin="0,5">
                    <TextBlock Style="{StaticResource TextBlockStyle}" Text="X" />
                    <TextBox Style="{StaticResource TextBoxStyle}" Template="{StaticResource FilletTextBox}" />
                </WrapPanel>
                <WrapPanel Margin="0,5">
                    <TextBlock Style="{StaticResource TextBlockStyle}" Text="Y" />
                    <TextBox Style="{StaticResource TextBoxStyle}" Template="{StaticResource FilletTextBox}" />
                </WrapPanel>
                <WrapPanel Margin="0,5">
                    <TextBlock Style="{StaticResource TextBlockStyle}" Text="R" />
                    <TextBox Style="{StaticResource TextBoxStyle}" Template="{StaticResource FilletTextBox}" />
                </WrapPanel>
            </StackPanel>
        </Grid>

        <Grid
            Grid.Row="1"
            Grid.Column="2"
            Height="360"
            HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
                <RowDefinition />
            </Grid.RowDefinitions>

            <WrapPanel
                Grid.Row="0"
                Margin="60,0,0,0"
                VerticalAlignment="Center">
                <Ellipse Style="{StaticResource EllipseStyle}" />
                <TextBlock
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Text="设备运行" />
            </WrapPanel>

            <WrapPanel Grid.Row="1" VerticalAlignment="Center">
                <TextBox Style="{StaticResource TextBoxStyle1}" Template="{StaticResource FilletTextBox}" />
            </WrapPanel>

            <WrapPanel Grid.Row="2" VerticalAlignment="Center">
                <Button
                    Width="30"
                    Height="30"
                    Margin="0,0,10,0" />
                <Button Content="取料启动" Style="{StaticResource ButtonStyle4}" />
                <Ellipse Style="{StaticResource EllipseStyle}" />
                <TextBlock
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="#ffffff"
                    Text="取料完成" />
            </WrapPanel>

            <WrapPanel Grid.Row="3" VerticalAlignment="Center">
                <TextBox Style="{StaticResource TextBoxStyle1}" Template="{StaticResource FilletTextBox}" />
                <Image
                    Height="28"
                    Margin="70,0,0,0"
                    Source="/Resources/向下箭头.jpg" />
            </WrapPanel>

            <WrapPanel Grid.Row="4" VerticalAlignment="Center">
                <Button
                    Width="30"
                    Height="30"
                    Margin="0,0,10,0" />
                <Button Content="去拍照位" Style="{StaticResource ButtonStyle4}" />
                <Ellipse Style="{StaticResource EllipseStyle}" />
                <TextBlock
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="#ffffff"
                    Text="已到拍照位" />
            </WrapPanel>

            <WrapPanel Grid.Row="5" VerticalAlignment="Center">
                <TextBox Style="{StaticResource TextBoxStyle1}" Template="{StaticResource FilletTextBox}" />
                <Image
                    Height="28"
                    Margin="70,0,0,0"
                    Source="/Resources/向下箭头.jpg" />
            </WrapPanel>

            <WrapPanel Grid.Row="6" VerticalAlignment="Center">
                <Button
                    Width="30"
                    Height="30"
                    Margin="0,0,10,0" />
                <Button Content="1次拍照启动" Style="{StaticResource ButtonStyle4}" />
                <Ellipse Style="{StaticResource EllipseStyle}" />
                <TextBlock
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="#ffffff"
                    Text="已拍照偏移完成" />
            </WrapPanel>

            <WrapPanel Grid.Row="7" VerticalAlignment="Center">
                <TextBox
                    Style="{StaticResource TextBoxStyle1}"
                    Template="{StaticResource FilletTextBox}"
                    Visibility="Hidden" />
                <Image
                    Height="28"
                    Margin="70,0,0,0"
                    Source="/Resources/向下箭头.jpg" />
            </WrapPanel>

            <WrapPanel Grid.Row="8" VerticalAlignment="Center">
                <Button
                    Width="30"
                    Height="30"
                    Margin="0,0,10,0"
                    Visibility="Hidden" />
                <Button Content="2次拍照启动" Style="{StaticResource ButtonStyle4}" />
                <Ellipse Style="{StaticResource EllipseStyle}" />
                <TextBlock
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="#ffffff"
                    Text="拍照完成" />
            </WrapPanel>

            <WrapPanel Grid.Row="9" VerticalAlignment="Center">
                <TextBox Style="{StaticResource TextBoxStyle1}" Template="{StaticResource FilletTextBox}" />
                <Image
                    Height="28"
                    Margin="70,0,0,0"
                    Source="/Resources/向下箭头.jpg" />
            </WrapPanel>

            <WrapPanel Grid.Row="10" VerticalAlignment="Center">
                <Button
                    Width="30"
                    Height="30"
                    Margin="0,0,10,0" />
                <Button Content="去放料" Style="{StaticResource ButtonStyle4}" />
                <Ellipse Style="{StaticResource EllipseStyle}" />
                <TextBlock
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    Foreground="#ffffff"
                    Text="放料完成" />
            </WrapPanel>
        </Grid>
    </Grid>
</UserControl>
